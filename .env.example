# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Application name (used in emails, logs, UI)
APP_NAME=Aventura

# Environment: local, development, staging, production
APP_ENV=local

# Application key (generate with: php artisan key:generate)
APP_KEY=

# Enable debug mode in development (NEVER true in production)
APP_DEBUG=true

# Public URL where the application is accessible
APP_URL=http://localhost

# Default application language
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance mode configuration
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Number of PHP CLI workers for handling requests
# PHP_CLI_SERVER_WORKERS=4

# ============================================================================
# SECURITY & HASHING
# ============================================================================

# Bcrypt hashing rounds (higher = slower but more secure, 12 is default)
BCRYPT_ROUNDS=12

# ============================================================================
# LOGGING
# ============================================================================

# Log channel: single, daily, slack, syslog, errorlog
LOG_CHANNEL=stack
LOG_STACK=single

# Deprecation warnings log channel
LOG_DEPRECATIONS_CHANNEL=null

# Log level: debug, info, notice, warning, error, critical, alert, emergency
LOG_LEVEL=debug

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Database connection: sqlite, mysql, pgsql, sqlsrv
DB_CONNECTION=sqlite

# MySQL/PostgreSQL specific settings (comment out for SQLite)
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# ============================================================================
# SESSION CONFIGURATION
# ============================================================================

# Session driver: database, file, cookie, memcached, redis
SESSION_DRIVER=database

# Session lifetime in minutes
SESSION_LIFETIME=120

# Encrypt session data
SESSION_ENCRYPT=false

# Session cookie path and domain
SESSION_PATH=/
SESSION_DOMAIN=null

# ============================================================================
# CACHE & BROADCASTING
# ============================================================================

# Broadcasting driver: log, redis, pusher, ably
BROADCAST_CONNECTION=log

# File storage disk
FILESYSTEM_DISK=local

# Queue driver: database, redis, sqs, sync, beanstalkd
QUEUE_CONNECTION=database

# Cache store: database, file, memcached, redis, dynamodb
CACHE_STORE=database
# CACHE_PREFIX=

# ============================================================================
# REDIS CONFIGURATION (if using Redis)
# ============================================================================

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================================================
# MAIL CONFIGURATION
# ============================================================================

# Mail driver: smtp, sendmail, mailgun, ses, resend, log, array
MAIL_MAILER=log

# SMTP settings
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null

# Default "from" address and name for outgoing emails
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================================
# AWS CONFIGURATION (for S3 file storage)
# ============================================================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================================================
# FRONTEND (VITE)
# ============================================================================

# App name exposed to frontend (React)
VITE_APP_NAME="${APP_NAME}"
